{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "po_candidate_rows_v1",
  "title": "po_candidate_rows_v1",
  "description": "LLM-authored candidate playbook rows + optional support sections. Validated and emitted by Python; LLM does not author final markdown.",
  "type": "object",
  "required": ["schema_version", "rows", "support_sections", "compiler_warnings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "po_candidate_rows_v1" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    },
    "support_sections": {
      "type": "object",
      "required": ["plan_context", "phase_details", "shared_guidance", "risks_and_contingencies", "immediate_next_actions"],
      "additionalProperties": false,
      "properties": {
        "plan_context": { "type": "string" },
        "phase_details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase_slug", "title", "body"],
            "additionalProperties": false,
            "properties": {
              "phase_slug": { "type": "string" },
              "title": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        },
        "shared_guidance": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "body"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        },
        "risks_and_contingencies": { "type": "string" },
        "immediate_next_actions": { "type": "string" }
      }
    },
    "compiler_warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "row": {
      "type": "object",
      "required": [
        "step_id",
        "phase",
        "action",
        "why_now",
        "owner_type",
        "prerequisites",
        "repo_surfaces",
        "deliverable",
        "exit_criteria",
        "allowed_write_roots",
        "requires_red_green"
      ],
      "additionalProperties": false,
      "properties": {
        "step_id": { "type": "string", "pattern": "^[0-9]{2}$" },
        "phase": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "why_now": { "type": "string", "minLength": 1 },
        "owner_type": { "type": "string", "minLength": 1 },
        "prerequisites": { "type": "string" },
        "repo_surfaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "deliverable": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "exit_criteria": { "type": "string", "minLength": 1 },
        "allowed_write_roots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "requires_red_green": { "type": "boolean" },
        "manual_gate": {
          "type": "string",
          "enum": ["none", "signoff", "approval", "operator_confirmation", "security_review", "presenter_review", "custom"]
        },
        "manual_gate_reason": { "type": "string" },
        "manual_gate_evidence": { "type": "array", "items": { "type": "string" } },
        "external_check": {
          "type": "string",
          "enum": ["none", "human_supplied_evidence_required"]
        },
        "external_dependencies": { "type": "array", "items": { "type": "string" } },
        "consult_paths": { "type": "array", "items": { "type": "string" } },
        "required_verification_commands": { "type": "array", "items": { "type": "string" } },
        "required_verification_artifacts": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
